#!/usr/bin/env bash
set -eo pipefail

# shellcheck source=ghcli-common.sh
source "$(dirname "$0")/ghcli-common.sh"

PR_TEMPLATE=$(mktemp --tmpdir gh-create-pr.XXXXXX)
COMMIT_MSGS=$(mktemp --tmpdir gh-create-pr.XXXXXX)
trap cleanup 1 2 15

cleanup() {
  if [[ -n "${PR_TEMPLATE:-}" ]]; then
    rm -f "$PR_TEMPLATE"
  fi
  if [[ -n "${COMMIT_MSGS:-}" ]]; then
    rm -f "$COMMIT_MSGS"
  fi
}

base_template() {
  echo "${GH_CLI_PR_TEMPLATE:-$(dirname "$0")/.github/pull_request_template.md}"
}

usage() {
  local exit=${1:-1}
  cat <<EOF

Usage: gh-create-pr [flags] [gh pr create flags]

Creates a pull request using a template populated with commit messages
from the current branch since the default branch.

The PR title is taken from the last commit message on the branch.
The PR body is generated from the template with @COMMIT_MSGS@ replaced
by the commit messages since the default branch.

Flags
  -h, --help      Show this help message
  -n, --dry-run   Print the PR body to stdout instead of creating the PR

env:
  GH_CLI_PR_TEMPLATE  Path to the PR template file
                      (default: .github/pull_request_template.md
                       relative to this script)

Any additional flags after '--' are passed directly to 'gh pr create'.

EOF
  exit "$exit"
}

main_branch() {
  git remote show "origin" | grep 'HEAD branch' | cut -d' ' -f5
}

commit_msgs() {
  local main="$1"
  git log --format=format:'- %s' "$main..$(git branch --show-current)" >"$COMMIT_MSGS"
}

create_pr_template() {
  local main="$1"
  local issue_ref
  issue_ref="$(gh_branch_issue_ref)"
  awk -v msgs_file="$COMMIT_MSGS" -v issue_ref="$issue_ref" '
    /@COMMIT_MSGS@/{while ((getline line < msgs_file) > 0) print line; close(msgs_file); next}
    /@BRANCH_ISSUE_REF@/{print issue_ref; next}
    1' "$(base_template)" >>"$PR_TEMPLATE"
}

{
  dry_run=0
  ARGS=$(getopt --options 'hn' --longoptions 'help,dry-run' -- "${@}")
  eval "set -- ${ARGS}"
  while true; do
    case "${1}" in
    -h | --help)
      usage "0"
      ;;
    -n | --dry-run)
      dry_run=1
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      usage
      ;;
    esac
  done
  main="$(main_branch)"
  commit_msgs "$main"
  create_pr_template "$main"
  pr_title="$(tail -n 1 "$COMMIT_MSGS")"
  pr_title="${pr_title/#- /}"

  if [[ "$dry_run" -eq 1 ]]; then
    echo -e "$pr_title\n"
    cat "$PR_TEMPLATE"
  else
    declare -a gh_args
    gh_args+=("--body-file")
    gh_args+=("$PR_TEMPLATE")
    gh_args+=("--title")
    gh_args+=("$pr_title")
    gh pr create "${gh_args[@]}" "$@"
  fi
  cleanup
}
